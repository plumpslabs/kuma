{
  "name": "@plumpslabs/kuma",
  "version": "2.2.5",
  "description": "Zero-setup safety toolkit for AI coding agents. MCP server with code review, git analysis, file editing, session memory, and static analysis — works with Claude Code, Cursor, Gemini CLI.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kuma": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --out-dir dist",
    "dev": "tsup src/index.ts --format esm --watch --out-dir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linting configured'",
    "prepublishOnly": "npm run build",
    "test": "NODE_OPTIONS=--experimental-vm-modules pnpm exec jest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "fast-glob": "^3.3.2",
    "sql.js": "^1.14.1",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "typescript-language-server": "^5.3.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "jest-mock": "^30.4.1",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "llm",
    "claude",
    "claude-code",
    "cursor",
    "coding-agent",
    "agentic",
    "developer-tools",
    "code-review",
    "static-analysis",
    "git-diff",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plumpslabs/kuma.git"
  },
  "bugs": {
    "url": "https://github.com/plumpslabs/kuma/issues"
  },
  "homepage": "https://github.com/plumpslabs/kuma#readme",
  "license": "MIT"
}
